---
const PACKAGE_NAME = 'git-watchtower';

let monthly: number | null = null;

try {
  const res = await fetch(
    `https://api.npmjs.org/downloads/point/last-month/${PACKAGE_NAME}`,
    { signal: AbortSignal.timeout(5000) }
  );
  if (res.ok) {
    const data = (await res.json()) as { downloads?: number };
    if (typeof data.downloads === 'number') monthly = data.downloads;
  }
} catch {
  monthly = null;
}

const exact = monthly !== null ? monthly.toLocaleString('en-US') : null;
---

{
  exact && (
    <a
      class="gw-header-downloads"
      href={`https://www.npmjs.com/package/${PACKAGE_NAME}`}
      target="_blank"
      rel="noopener"
      title={`${exact} downloads in the last 30 days`}
    >
      <span class="gw-hd-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M12 4v11m0 0l-4-4m4 4l4-4M5 19h14"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="gw-hd-text">
        <span class="gw-hd-num">{exact}</span>
        <span class="gw-hd-label">downloads in the last 30 days</span>
      </span>
    </a>
  )
}

<style>
  .gw-header-downloads {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(74, 222, 128, 0.3);
    background: rgba(74, 222, 128, 0.06);
    color: var(--sl-color-white);
    font-family: var(--sl-font);
    font-size: 0.8rem;
    line-height: 1;
    text-decoration: none;
    opacity: 0;
    transform: translateX(-24px);
    animation: gw-hd-slide 0.85s cubic-bezier(0.2, 0.8, 0.25, 1) 0.35s both,
      gw-hd-shine 6s ease-in-out 1.4s infinite;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      transform 0.2s ease;
    overflow: hidden;
    position: relative;
  }

  :root[data-theme='light'] .gw-header-downloads {
    color: var(--sl-color-black);
    background: rgba(22, 163, 74, 0.08);
    border-color: rgba(22, 163, 74, 0.3);
  }

  .gw-header-downloads:hover {
    border-color: rgba(74, 222, 128, 0.6);
    background: rgba(74, 222, 128, 0.12);
    transform: translateY(-1px);
  }

  .gw-hd-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    color: var(--sl-color-accent);
    flex: none;
  }

  .gw-hd-icon svg {
    width: 12px;
    height: 12px;
    display: block;
  }

  .gw-hd-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .gw-hd-num {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-accent);
    letter-spacing: -0.01em;
  }

  :root[data-theme='light'] .gw-hd-num {
    color: var(--sl-color-accent-high);
  }

  .gw-hd-label {
    opacity: 0.75;
  }

  @keyframes gw-hd-slide {
    0% {
      opacity: 0;
      transform: translateX(-24px);
    }
    60% {
      opacity: 1;
      transform: translateX(3px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes gw-hd-shine {
    0%,
    85%,
    100% {
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0);
    }
    90% {
      box-shadow: 0 0 14px 0 rgba(74, 222, 128, 0.35);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gw-header-downloads {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* Narrow screens: collapse the label, keep the number */
  @media (max-width: 62em) {
    .gw-hd-label {
      display: none;
    }
  }

  /* Very small screens: hide entirely to preserve space for icons */
  @media (max-width: 32em) {
    .gw-header-downloads {
      display: none;
    }
  }
</style>
