---
const { href = '/guides/quick-start/', label = 'Read the full documentation' } = Astro.props;

// Column of glyphs for the matrix rain rails
const GLYPHS = '01{}[]</>=+-*#$&|~^?!:.;git·commit·branch·HEAD·fetch·pull·merge·tree·watch';
const glyphChars = GLYPHS.split('');
function column(seed: number, length: number): string[] {
  const out: string[] = [];
  let n = seed;
  for (let i = 0; i < length; i++) {
    n = (n * 1103515245 + 12345) & 0x7fffffff;
    out.push(glyphChars[n % glyphChars.length]);
  }
  return out;
}
const leftRail = column(7, 40);
const rightRail = column(31, 40);
---

<div class="gw-cta">
  <div class="gw-cta-rain gw-cta-rain--left" aria-hidden="true">
    {leftRail.map((c, i) => <span style={`--d:${(i % 7) * 0.15}s`}>{c}</span>)}
  </div>
  <div class="gw-cta-rain gw-cta-rain--right" aria-hidden="true">
    {rightRail.map((c, i) => <span style={`--d:${(i % 9) * 0.13}s`}>{c}</span>)}
  </div>

  <div class="gw-cta-panel">
    <div class="gw-cta-chrome" aria-hidden="true">
      <span class="gw-dot gw-dot--r"></span>
      <span class="gw-dot gw-dot--y"></span>
      <span class="gw-dot gw-dot--g"></span>
      <span class="gw-cta-title">~/projects/your-repo — git-watchtower</span>
    </div>
    <div class="gw-cta-body">
      <div class="gw-line">
        <span class="gw-prompt">$</span>
        <span class="gw-type gw-type--1">git-watchtower --docs</span>
      </div>
      <div class="gw-line gw-line--2">
        <span class="gw-out">› launching watchtower…</span>
      </div>
      <div class="gw-line gw-line--3">
        <span class="gw-ok">[OK]</span>
        <span class="gw-out">ready. docs loaded.</span>
      </div>
      <a class="gw-cta-link" href={href}>
        <span class="gw-prompt">❯</span>
        <span>{label}</span>
        <span class="gw-arrow" aria-hidden="true">→</span>
        <span class="gw-cursor" aria-hidden="true"></span>
      </a>
    </div>
  </div>
</div>

<style>
  .gw-cta {
    position: relative;
    margin-top: 4rem;
    padding: 0;
    display: flex;
    justify-content: center;
    overflow: hidden;
    border-radius: 14px;
    isolation: isolate;
  }

  /* Panel */
  .gw-cta-panel {
    position: relative;
    width: min(100%, 640px);
    background: linear-gradient(180deg, #0d1117 0%, #0a0d13 100%);
    border: 1px solid rgba(74, 222, 128, 0.22);
    border-radius: 12px;
    box-shadow:
      0 0 0 1px rgba(74, 222, 128, 0.06),
      0 10px 40px -10px rgba(0, 0, 0, 0.5),
      0 0 60px -20px rgba(74, 222, 128, 0.3);
    overflow: hidden;
    z-index: 1;
  }

  /* Subtle scanline overlay */
  .gw-cta-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(74, 222, 128, 0.025) 2px,
      rgba(74, 222, 128, 0.025) 3px
    );
    pointer-events: none;
    z-index: 0;
  }

  .gw-cta-chrome {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-family: var(--sl-font-system-mono);
    font-size: 0.72rem;
    color: #7d8590;
  }

  .gw-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex: none;
  }
  .gw-dot--r { background: #ff5f56; }
  .gw-dot--y { background: #ffbd2e; }
  .gw-dot--g { background: #27c93f; }
  .gw-cta-title {
    margin-left: 0.4rem;
    opacity: 0.7;
  }

  .gw-cta-body {
    position: relative;
    padding: 1.4rem 1.5rem 1.5rem;
    font-family: var(--sl-font-system-mono);
    font-size: 0.92rem;
    line-height: 1.7;
    color: #d5dde6;
    z-index: 1;
  }

  .gw-line {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    opacity: 0;
    animation: gw-cta-fade 0.4s ease-out forwards;
  }
  .gw-line--2 { animation-delay: 1.4s; }
  .gw-line--3 { animation-delay: 2.0s; }

  @keyframes gw-cta-fade {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .gw-prompt {
    color: #4ade80;
    font-weight: 700;
    flex: none;
  }

  .gw-ok {
    color: #4ade80;
    font-weight: 600;
    font-size: 0.78rem;
    padding: 0.05rem 0.35rem;
    border: 1px solid rgba(74, 222, 128, 0.35);
    border-radius: 4px;
    flex: none;
  }

  .gw-out {
    color: #a2acba;
  }

  /* Typewriter effect on the first command */
  .gw-type--1 {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid #4ade80;
    width: 0;
    animation:
      gw-type-cmd 1.1s steps(22, end) 0.3s forwards,
      gw-caret 0.9s steps(1, end) 1.5s 2;
  }

  @keyframes gw-type-cmd {
    to { width: 22ch; }
  }

  @keyframes gw-caret {
    50% { border-color: transparent; }
  }

  /* CTA link */
  .gw-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.1rem;
    padding: 0.55rem 0.85rem;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.35);
    border-radius: 6px;
    color: #bbf7d0;
    text-decoration: none;
    font-family: var(--sl-font-system-mono);
    font-size: 0.92rem;
    font-weight: 600;
    opacity: 0;
    animation: gw-cta-fade 0.4s ease-out 2.5s forwards;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      transform 0.1s ease,
      color 0.15s ease;
  }

  .gw-cta-link:hover {
    background: rgba(74, 222, 128, 0.16);
    border-color: rgba(74, 222, 128, 0.6);
    color: #fff;
  }

  .gw-cta-link:active {
    transform: translateY(1px);
  }

  .gw-arrow {
    margin-left: 0.15rem;
    transition: transform 0.2s ease;
  }
  .gw-cta-link:hover .gw-arrow {
    transform: translateX(3px);
  }

  .gw-cursor {
    width: 8px;
    height: 1.1em;
    background: #4ade80;
    display: inline-block;
    margin-left: 0.1rem;
    animation: gw-caret 1s steps(1, end) infinite;
  }

  /* Matrix rain rails */
  .gw-cta-rain {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 180px;
    display: flex;
    flex-direction: column;
    font-family: var(--sl-font-system-mono);
    font-size: 0.72rem;
    line-height: 1.3;
    color: rgba(74, 222, 128, 0.75);
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }
  .gw-cta-rain--left {
    left: 0;
    mask-image: linear-gradient(to right, black 0%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 0%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }
  .gw-cta-rain--right {
    right: 0;
    mask-image: linear-gradient(to left, black 0%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .gw-cta-rain span {
    display: inline-block;
    opacity: 0;
    transform: translateY(-30px);
    animation: gw-rain 5s linear infinite;
    animation-delay: var(--d, 0s);
  }

  @keyframes gw-rain {
    0% {
      opacity: 0;
      transform: translateY(-30px);
    }
    10% {
      opacity: 0.85;
    }
    85% {
      opacity: 0.25;
    }
    100% {
      opacity: 0;
      transform: translateY(420px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gw-line,
    .gw-cta-link {
      opacity: 1;
      animation: none;
    }
    .gw-type--1 {
      width: 22ch;
      animation: none;
      border-right-color: transparent;
    }
    .gw-cta-rain span,
    .gw-cursor {
      animation: none;
    }
  }

  /* Narrow the rain rails on small screens */
  @media (max-width: 50em) {
    .gw-cta-rain {
      width: 80px;
      font-size: 0.65rem;
    }
  }

  @media (max-width: 32em) {
    .gw-cta-rain {
      display: none;
    }
    .gw-cta-panel {
      width: 100%;
    }
    .gw-cta-body {
      padding: 1.2rem 1rem 1.3rem;
      font-size: 0.85rem;
    }
  }
</style>
