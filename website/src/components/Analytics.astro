---
const apiKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const apiHost = import.meta.env.PUBLIC_POSTHOG_HOST ?? 'https://us.i.posthog.com';
---

{
  apiKey && (
    <script is:inline define:vars={{ apiKey, apiHost }}>
      window.__GW_POSTHOG_CONFIG = { apiKey, apiHost };
    </script>
  )
}

{
  apiKey && (
    <script>
      import posthog from 'posthog-js';

      type ScrollSentinel = { threshold: number; fired: boolean };

      const config = (window as unknown as { __GW_POSTHOG_CONFIG?: { apiKey: string; apiHost: string } })
        .__GW_POSTHOG_CONFIG;

      function sectionFromPath(path: string): string {
        if (path === '/' || path === '') return 'landing';
        if (path.startsWith('/casino')) return 'casino';
        if (path.startsWith('/guides')) return 'docs';
        return 'other';
      }

      function initPostHog() {
        if (!config) return;
        posthog.init(config.apiKey, {
          api_host: config.apiHost,
          capture_pageview: 'history_change',
          capture_pageleave: true,
          capture_performance: { web_vitals: true },
          autocapture: true,
          persistence: 'localStorage',
          respect_dnt: true,
          session_recording: { maskAllInputs: true },
          loaded: (ph) => {
            ph.register({ site_section: sectionFromPath(window.location.pathname) });
          },
        });
      }

      function isOutbound(href: string): boolean {
        try {
          const url = new URL(href, window.location.href);
          return url.origin !== window.location.origin && /^https?:$/.test(url.protocol);
        } catch {
          return false;
        }
      }

      function trackOutboundClicks() {
        document.addEventListener(
          'click',
          (event) => {
            const target = event.target as HTMLElement | null;
            const anchor = target?.closest?.('a[href]') as HTMLAnchorElement | null;
            if (!anchor) return;
            const href = anchor.getAttribute('href') ?? '';
            if (!isOutbound(href)) return;
            posthog.capture('outbound_link_click', {
              href,
              text: (anchor.textContent ?? '').trim().slice(0, 120),
              host: new URL(href, window.location.href).host,
            });
          },
          { capture: true }
        );
      }

      function trackCodeBlockCopies() {
        document.addEventListener(
          'click',
          (event) => {
            const target = event.target as HTMLElement | null;
            const button = target?.closest?.('.expressive-code .copy button') as HTMLButtonElement | null;
            if (!button) return;
            const pre = button.closest('.expressive-code')?.querySelector('pre');
            const command = (pre?.textContent ?? '').trim().slice(0, 240);
            posthog.capture('code_block_copied', {
              command,
              page: window.location.pathname,
            });
          },
          { capture: true }
        );
      }

      function trackSearch() {
        const target = document.querySelector('site-search') ?? document;
        target.addEventListener(
          'submit',
          (event) => {
            const form = event.target as HTMLFormElement | null;
            const input = form?.querySelector?.('input[type="search"], input[name="q"]') as HTMLInputElement | null;
            const query = (input?.value ?? '').trim();
            if (!query) return;
            posthog.capture('search_used', { query, page: window.location.pathname });
          },
          { capture: true }
        );
      }

      function trackCasinoEgg() {
        document.addEventListener(
          'click',
          (event) => {
            const target = event.target as HTMLElement | null;
            const link = target?.closest?.('a.casino-link') as HTMLAnchorElement | null;
            if (!link) return;
            posthog.capture('casino_easter_egg_found');
          },
          { capture: true }
        );
      }

      function setupScrollDepth() {
        if (window.location.pathname !== '/' && window.location.pathname !== '') return;

        const sentinels: ScrollSentinel[] = [
          { threshold: 25, fired: false },
          { threshold: 50, fired: false },
          { threshold: 75, fired: false },
          { threshold: 100, fired: false },
        ];

        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const doc = document.documentElement;
            const scrollable = Math.max(doc.scrollHeight - window.innerHeight, 1);
            const pct = Math.min(100, Math.round(((window.scrollY + window.innerHeight) / doc.scrollHeight) * 100));
            const reachedBottom = window.scrollY + window.innerHeight >= scrollable + doc.scrollHeight - scrollable - 4;
            sentinels.forEach((s) => {
              if (s.fired) return;
              if (pct >= s.threshold || (s.threshold === 100 && reachedBottom)) {
                s.fired = true;
                posthog.capture('scroll_depth', { threshold: s.threshold });
              }
            });
            ticking = false;
          });
        };

        window.addEventListener('scroll', onScroll, { passive: true });
      }

      initPostHog();
      trackOutboundClicks();
      trackCodeBlockCopies();
      trackSearch();
      trackCasinoEgg();
      setupScrollDepth();

      document.addEventListener('astro:page-load', () => {
        posthog.register({ site_section: sectionFromPath(window.location.pathname) });
        setupScrollDepth();
      });
    </script>
  )
}
