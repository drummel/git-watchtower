---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="gw-site-title" aria-label="Git Watchtower">
  <span class="gw-status" aria-hidden="true"></span>
  <span class="gw-wordmark" translate="no">git-watchtower</span>
</a>

<style>
  .gw-site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
    padding: 0.35rem 0.1rem;
    line-height: 1;
  }

  .gw-status {
    flex: none;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--sl-color-accent);
    box-shadow:
      0 0 0 2px rgba(34, 197, 94, 0.12),
      0 0 8px rgba(34, 197, 94, 0.6);
    position: relative;
  }

  .gw-status::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.45);
    animation: gw-status-pulse 2.4s ease-out infinite;
  }

  @keyframes gw-status-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.45);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gw-status::after {
      animation: none;
    }
  }

  .gw-wordmark {
    font-family: var(--sl-font-system-mono);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--sl-color-white);
    transition: color 0.15s ease;
  }

  :root[data-theme='light'] .gw-wordmark {
    color: var(--sl-color-black);
  }

  .gw-site-title:hover .gw-wordmark {
    color: var(--sl-color-accent-high);
  }

  :root[data-theme='light'] .gw-site-title:hover .gw-wordmark {
    color: var(--sl-color-accent);
  }
</style>
